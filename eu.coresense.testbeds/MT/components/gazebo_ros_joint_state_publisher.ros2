gazebo_ros_joint_state_publisher:
  artifacts:
    gazebo_ros_joint_state_publisher:
      node: gazebo_ros_joint_state_publisher
      publishers:
        'joint_states':
          type: 'sensor_msgs/msg/JointState'
          qos:
          # profile:
          # history: UNKNOWN
          # depth:
            reliability: reliable
            durability: volatile
      subscribers:
        'clock':
          type: 'rosgraph_msgs/msg/Clock'
